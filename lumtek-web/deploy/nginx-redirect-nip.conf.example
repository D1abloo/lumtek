# Redirección 301 desde el dominio nip.io antiguo (opcional, tras migrar a lumtek.es)
# Copiar a /etc/nginx/sites-available/lumtek-redirect-nip
# ln -sf /etc/nginx/sites-available/lumtek-redirect-nip /etc/nginx/sites-enabled/
# nginx -t && systemctl reload nginx

server {
    listen 80;
    listen [::]:80;
    server_name lumtek.31.70.109.174.nip.io;
    return 301 https://lumtek.es$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name lumtek.31.70.109.174.nip.io;

    # Reutiliza el certificado nip.io existente hasta que deje de usarse
    ssl_certificate /etc/letsencrypt/live/lumtek.31.70.109.174.nip.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/lumtek.31.70.109.174.nip.io/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    return 301 https://lumtek.es$request_uri;
}
