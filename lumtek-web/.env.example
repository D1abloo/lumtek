# =============================================================================
# Lumtek — variables de entorno (copia a .env y rellena SMTP_PASS)
# cp .env.example .env
# =============================================================================

# --- Frontend (Vite) ---
VITE_CONTACT_ENDPOINT=/api/contact

# --- API Node (server/index.mjs) ---
PORT=3001
NODE_ENV=production

# --- SMTP GoDaddy (correo Professional Email / Workspace) ---
# Panel: https://email.godaddy.com → Configuración → SMTP
# Servidor saliente: smtpout.secureserver.net
# Usuario: tu email completo (ej. juanf.delgado@lumtek.es)
# Contraseña: la del buzón (no la de GoDaddy account)

SMTP_HOST=smtpout.secureserver.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_REQUIRE_TLS=true
SMTP_USER=juanf.delgado@lumtek.es
SMTP_PASS=
MAIL_TO=juanf.delgado@lumtek.es
MAIL_FROM_NAME=Lumtek Web

# Alternativa GoDaddy con TLS en puerto 587:
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true

# Si el correo es Microsoft 365 gestionado por GoDaddy:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_REQUIRE_TLS=true

# --- CORS (opcional; en producción suele bastar el mismo dominio) ---
# CORS_ORIGIN=https://lumtek.31.70.109.174.nip.io
